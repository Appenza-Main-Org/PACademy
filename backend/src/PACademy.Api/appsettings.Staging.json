{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Otp": {
    "Transport": "Sms",
    "ValidityMinutes": 5
  },
  "OfficerLookup": {
    "Source": "MOIPASS",
    "Moipass": {
      "BaseUrl": null,
      "ApiKey": null
    }
  },
  "LockPolicy": {
    "Defaults": {
      "MaxFailedAttempts": 5,
      "LockDurationMinutes": 30
    }
  }
}
