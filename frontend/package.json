{
  "name": "police-academy-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Police Academy Admissions Platform — production-grade React frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:routes": "node scripts/test-routes.mjs",
    "test:routes:prod": "node scripts/test-routes.mjs https://pa-cademy.vercel.app"
  },
  "dependencies": {
