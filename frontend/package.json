    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-plugin-boundaries": "^4.2.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.5",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
