{
  "info": {
    "name": "ZKBioTime API",
    "_postman_id": "f1a2b3c4-d5e6-47a8-9b10-zkbiotime0001",
    "description": "ZKBioTime / BioTime 8.x REST API test collection.\n\nDocs: https://zkbiotime.xmzkteco.com/docs/api-docs/\n\nUsage:\n1. Set the `base_url`, `username`, `password` variables (collection or environment).\n2. Run **Authentication → Get JWT Token** first — its test script captures `{{token}}` automatically.\n3. All other requests send `Authorization: Token {{token}}` via collection-level auth.\n\nNote: a static general token is preconfigured in `{{token}}`, so you can skip the Authentication folder entirely.\n\nResources covered: Authentication, Area, Department, Position, Employee, Resign, Device (Terminal), Transaction, Transaction Report.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "Authorization", "type": "string" },
      { "key": "value", "value": "Token {{token}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1", "type": "string" },
    { "key": "username", "value": "", "type": "string" },
    { "key": "password", "value": "", "type": "string" },
    { "key": "token", "value": "d871d36636368811e83db9ca81e9a4136c04b46b", "type": "string" },
    { "key": "emp_code", "value": "1", "type": "string" },
    { "key": "page_size", "value": "100", "type": "string" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  pm.environment.set('token', res.token);",
                  "  console.log('Saved JWT token');",
                  "}",
                  "pm.test('200 OK and token returned', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(res.token).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/jwt-api-token-auth/",
              "host": ["{{base_url}}"],
              "path": ["jwt-api-token-auth", ""]
            },
            "description": "Obtain a JWT auth token. The test script stores it as {{token}} for every other request.\n\nHeader used elsewhere: `Authorization: JWT <token>`."
          }
        },
        {
          "name": "Get General Token (alt)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api-token-auth/",
              "host": ["{{base_url}}"],
              "path": ["api-token-auth", ""]
            },
            "description": "Alternative general (non-JWT) token. If you use this, the header becomes `Authorization: Token <token>` instead of `JWT`."
          }
        }
      ]
    },
